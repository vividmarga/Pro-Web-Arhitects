            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block font-mono text-xs uppercase tracking-widest text-on-surface-variant mb-2" data-key="form_name">Full Name *</label>
                <input id="c-name" type="text" required placeholder="John Doe" class="w-full bg-surface-container-low px-4 py-3 text-on-surface text-sm border border-outline-variant focus:border-primary focus:outline-none transition-colors"/>
              </div>
              <div>
                <label class="block font-mono text-xs uppercase tracking-widest text-on-surface-variant mb-2" data-key="form_email">Email *</label>
                <input id="c-email" type="email" required placeholder="john@company.com" class="w-full bg-surface-container-low px-4 py-3 text-on-surface text-sm border border-outline-variant focus:border-primary focus:outline-none transition-colors"/>
              </div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block font-mono text-xs uppercase tracking-widest text-on-surface-variant mb-2" data-key="form_phone">Phone</label>
                <input id="c-phone" type="tel" placeholder="+40 7XX XXX XXX" class="w-full bg-surface-container-low px-4 py-3 text-on-surface text-sm border border-outline-variant focus:border-primary focus:outline-none transition-colors"/>
              </div>
              <div>
                <label class="block font-mono text-xs uppercase tracking-widest text-on-surface-variant mb-2" data-key="form_business">Business</label>
                <input id="c-business" type="text" placeholder="Your Company" class="w-full bg-surface-container-low px-4 py-3 text-on-surface text-sm border border-outline-variant focus:border-primary focus:outline-none transition-colors"/>
              </div>
            </div>
            <!-- Service pills -->
            <div>
              <label class="block font-mono text-xs uppercase tracking-widest text-on-surface-variant mb-3" data-key="form_service">Service Needed *</label>
              <div class="flex flex-wrap gap-3">
                <button type="button" class="srv-pill px-4 py-2 bg-surface-container-low border border-outline-variant font-label text-xs uppercase tracking-widest hover:border-primary transition-colors" data-value="E-Commerce" data-key="pill_ecom">E-Commerce</button>
                <button type="button" class="srv-pill px-4 py-2 bg-surface-container-low border border-outline-variant font-label text-xs uppercase tracking-widest hover:border-primary transition-colors" data-value="Landing Page" data-key="pill_land">Landing Page</button>
