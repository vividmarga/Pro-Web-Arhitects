<nav class="main-nav">
  <div class="max-w-[1440px] mx-auto px-6 py-4 flex items-center justify-between">
    <!-- Logo -->
    <a href="#" class="flex items-center gap-3">
      <div class="w-9 h-9 bg-primary flex items-center justify-center text-white font-black text-xl relative">
        P<div class="absolute inset-0 border border-secondary-container opacity-30"></div>
      </div>
      <span class="font-black tracking-tighter text-on-surface uppercase text-lg hidden sm:block">Pro Web Architects</span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden lg:flex items-center gap-8">
      <a href="#services" class="nav-link font-label text-xs uppercase tracking-widest text-on-surface-variant hover:text-primary transition-colors" data-key="nav_services">Services</a>
      <a href="#portfolio" class="nav-link font-label text-xs uppercase tracking-widest text-on-surface-variant hover:text-primary transition-colors" data-key="nav_portfolio">Portfolio</a>
      <a href="#methodology" class="nav-link font-label text-xs uppercase tracking-widest text-on-surface-variant hover:text-primary transition-colors" data-key="nav_methodology">Methodology</a>
      <a href="#pricing" class="nav-link font-label text-xs uppercase tracking-widest text-on-surface-variant hover:text-primary transition-colors" data-key="nav_pricing">Pricing</a>
      <a href="#blog" class="nav-link font-label text-xs uppercase tracking-widest text-on-surface-variant hover:text-primary transition-colors" data-key="nav_blog">Blog</a>
      <a href="#contact" class="nav-link font-label text-xs uppercase tracking-widest text-on-surface-variant hover:text-primary transition-colors" data-key="nav_contact">Contact</a>
    </div>

    <!-- Right actions -->
    <div class="flex items-center gap-3">
      <!-- Language switcher -->
      <div class="hidden md:flex items-center gap-1 border border-outline-variant px-2 py-1">
        <button class="lang-btn active" onclick="setLang('en')">EN</button>
        <span class="text-outline-variant text-xs">|</span>
        <button class="lang-btn" onclick="setLang('ro')">RO</button>
        <span class="text-outline-variant text-xs">|</span>
        <button class="lang-btn" onclick="setLang('fr')">FR</button>
        <span class="text-outline-variant text-xs">|</span>
        <button class="lang-btn" onclick="setLang('de')">DE</button>
      </div>
      <!-- Dark mode -->
      <button onclick="toggleDark()" class="w-9 h-9 flex items-center justify-center border border-outline-variant hover:border-primary transition-colors" title="Toggle dark mode">
        <span class="material-symbols-outlined text-base" id="darkIcon">dark_mode</span>
      </button>
      <!-- CTA -->
      <a href="#contact" class="shimmer hidden sm:block px-5 py-2 bg-primary text-white font-label text-xs uppercase tracking-widest hover:bg-primary-container transition-colors" data-key="nav_hire">Start a Project</a>
      <!-- Hamburger -->
      <button class="lg:hidden w-9 h-9 flex items-center justify-center" onclick="toggleMobileMenu()">
        <span class="material-symbols-outlined">menu</span>
      </button>
    </div>
  </div>
</nav>

<!-- Mobile Menu -->
<div class="mobile-menu" id="mobileMenu">
  <div class="flex flex-col h-full px-8 pt-24 pb-12">
    <button onclick="toggleMobileMenu()" class="absolute top-6 right-6"><span class="material-symbols-outlined text-2xl">close</span></button>
    <div class="space-y-6 flex-1">
      <a href="#services" onclick="toggleMobileMenu()" class="block font-black text-4xl uppercase tracking-tighter hover:text-primary transition-colors" data-key="nav_services">Services</a>
      <a href="#portfolio" onclick="toggleMobileMenu()" class="block font-black text-4xl uppercase tracking-tighter hover:text-primary transition-colors" data-key="nav_portfolio">Portfolio</a>
      <a href="#methodology" onclick="toggleMobileMenu()" class="block font-black text-4xl uppercase tracking-tighter hover:text-primary transition-colors" data-key="nav_methodology">Methodology</a>
      <a href="#pricing" onclick="toggleMobileMenu()" class="block font-black text-4xl uppercase tracking-tighter hover:text-primary transition-colors" data-key="nav_pricing">Pricing</a>
      <a href="#blog" onclick="toggleMobileMenu()" class="block font-black text-4xl uppercase tracking-tighter hover:text-primary transition-colors" data-key="nav_blog">Blog</a>
      <a href="#contact" onclick="toggleMobileMenu()" class="block font-black text-4xl uppercase tracking-tighter hover:text-primary transition-colors" data-key="nav_contact">Contact</a>
    </div>
    <div class="flex gap-2 mt-8">
      <button class="lang-btn active" onclick="setLang('en');toggleMobileMenu()">EN</button>
      <button class="lang-btn" onclick="setLang('ro');toggleMobileMenu()">RO</button>
      <button class="lang-btn" onclick="setLang('fr');toggleMobileMenu()">FR</button>
      <button class="lang-btn" onclick="setLang('de');toggleMobileMenu()">DE</button>
    </div>
  </div>
</div>

