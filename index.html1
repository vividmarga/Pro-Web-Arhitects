  <div class="max-w-[1440px] mx-auto w-full relative z-10">
    <div class="max-w-3xl">
      <div class="fade-up flex items-center gap-4 mb-8">
        <span class="sec-label bg-primary/5 px-3 py-1" data-key="hero_badge">V.4.0 Engine · Now Accepting Projects</span>
