            </div>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-primary/10 flex items-center justify-center">
              <span class="material-symbols-outlined text-primary">lock</span>
            </div>
            <div>
              <div class="font-mono text-xs uppercase tracking-widest text-on-surface-variant mb-1" data-key="contact_priv_label">Privacy</div>
              <div class="font-bold uppercase" data-key="contact_priv">100% Confidential</div>
            </div>
          </div>
