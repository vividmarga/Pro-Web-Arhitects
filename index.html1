<!-- ═══════════════════════════════════════════════════
     FAQ
════════════════════════════════════════════════════ -->
<section id="faq" class="py-32 px-6 lg:px-24 bg-surface-container-low">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-20">
      <span class="sec-label block mb-4" data-key="faq_label">Got Questions?</span>
      <h2 class="font-black text-5xl md:text-7xl uppercase tracking-tighter" data-key="faq_title">FAQ</h2>
    </div>

    <div class="space-y-0" id="faqContainer">

      <div class="faq-item border-b border-outline-variant">
        <button class="w-full flex justify-between items-center py-7 text-left" onclick="toggleFaq(this)">
          <span class="font-bold uppercase text-lg pr-8" data-key="faq1_q">How long does a project take?</span>
          <span class="faq-toggle material-symbols-outlined text-primary flex-shrink-0">add</span>
        </button>
        <div class="faq-content">
          <p class="text-on-surface-variant text-sm leading-relaxed pb-7" data-key="faq1_a">A landing page takes 2–3 weeks. A full e-commerce site or corporate platform takes 4–8 weeks. We provide realistic timelines upfront and stick to them.</p>
        </div>
      </div>

      <div class="faq-item border-b border-outline-variant">
        <button class="w-full flex justify-between items-center py-7 text-left" onclick="toggleFaq(this)">
          <span class="font-bold uppercase text-lg pr-8" data-key="faq2_q">Why not use WordPress or Shopify?</span>
          <span class="faq-toggle material-symbols-outlined text-primary flex-shrink-0">add</span>
        </button>
        <div class="faq-content">
          <p class="text-on-surface-variant text-sm leading-relaxed pb-7" data-key="faq2_a">Templates limit you. Custom code means superior performance (sub-1s load), better security, unique design, and unlimited scalability. Your site shouldn't look like your competitor's.</p>
        </div>
      </div>

      <div class="faq-item border-b border-outline-variant">
        <button class="w-full flex justify-between items-center py-7 text-left" onclick="toggleFaq(this)">
          <span class="font-bold uppercase text-lg pr-8" data-key="faq3_q">What happens after launch?</span>
          <span class="faq-toggle material-symbols-outlined text-primary flex-shrink-0">add</span>
        </button>
        <div class="faq-content">
          <p class="text-on-surface-variant text-sm leading-relaxed pb-7" data-key="faq3_a">Full training on your CMS, 30–180 days post-launch support depending on plan, and optional monthly maintenance packages. You're never left alone.</p>
        </div>
      </div>

      <div class="faq-item border-b border-outline-variant">
        <button class="w-full flex justify-between items-center py-7 text-left" onclick="toggleFaq(this)">
          <span class="font-bold uppercase text-lg pr-8" data-key="faq4_q">Do you work with international clients?</span>
          <span class="faq-toggle material-symbols-outlined text-primary flex-shrink-0">add</span>
        </button>
        <div class="faq-content">
          <p class="text-on-surface-variant text-sm leading-relaxed pb-7" data-key="faq4_a">Yes. We work with clients across Europe and beyond. Communication in English, Romanian, French, and German. Time zone flexible.</p>
        </div>
      </div>

      <div class="faq-item border-b border-outline-variant">
        <button class="w-full flex justify-between items-center py-7 text-left" onclick="toggleFaq(this)">
          <span class="font-bold uppercase text-lg pr-8" data-key="faq5_q">How do payments work?</span>
          <span class="faq-toggle material-symbols-outlined text-primary flex-shrink-0">add</span>
        </button>
        <div class="faq-content">
          <p class="text-on-surface-variant text-sm leading-relaxed pb-7" data-key="faq5_a">50% upfront to begin, 50% on delivery. For larger projects, milestone-based payments are available. All major payment methods accepted.</p>
        </div>
      </div>

    </div>
  </div>
</section>

