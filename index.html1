        </div>
        <div>
          <div class="font-black text-3xl tracking-tighter text-primary">&lt;1s</div>
          <div class="font-mono text-xs text-on-surface-variant uppercase tracking-widest mt-1" data-key="stat_load">Load Time</div>
        </div>
        <div>
          <div class="font-black text-3xl tracking-tighter text-on-surface">99.9%</div>
          <div class="font-mono text-xs text-on-surface-variant uppercase tracking-widest mt-1" data-key="stat_uptime">Uptime SLA</div>
        </div>
        <div>
          <div class="font-black text-3xl tracking-tighter text-on-surface">5★</div>
          <div class="font-mono text-xs text-on-surface-variant uppercase tracking-widest mt-1" data-key="stat_rating">Client Rating</div>
        </div>
      </div>

      <div class="fade-up-4 flex flex-wrap gap-4">
