                <button type="button" class="srv-pill px-4 py-2 bg-surface-container-low border border-outline-variant font-label text-xs uppercase tracking-widest hover:border-primary transition-colors" data-value="Corporate" data-key="pill_corp">Corporate</button>
                <button type="button" class="srv-pill px-4 py-2 bg-surface-container-low border border-outline-variant font-label text-xs uppercase tracking-widest hover:border-primary transition-colors" data-value="Other" data-key="pill_other">Other</button>
              </div>
              <input type="hidden" id="c-service"/>
            </div>
            <!-- Budget -->
            <div>
              <label class="block font-mono text-xs uppercase tracking-widest text-on-surface-variant mb-3" data-key="form_budget">Budget Range</label>
              <div class="flex flex-wrap gap-3">
                <button type="button" class="bgt-pill px-4 py-2 bg-surface-container-low border border-outline-variant font-label text-xs uppercase tracking-widest hover:border-secondary transition-colors" data-value="Under €500">Under €500</button>
                <button type="button" class="bgt-pill px-4 py-2 bg-surface-container-low border border-outline-variant font-label text-xs uppercase tracking-widest hover:border-secondary transition-colors" data-value="€500–€1.5k">€500–€1.5k</button>
                <button type="button" class="bgt-pill px-4 py-2 bg-surface-container-low border border-outline-variant font-label text-xs uppercase tracking-widest hover:border-secondary transition-colors" data-value="€1.5k–€5k">€1.5k–€5k</button>
                <button type="button" class="bgt-pill px-4 py-2 bg-surface-container-low border border-outline-variant font-label text-xs uppercase tracking-widest hover:border-secondary transition-colors" data-value="€5k+">€5k+</button>
              </div>
              <input type="hidden" id="c-budget"/>
            </div>
            <div>
              <label class="block font-mono text-xs uppercase tracking-widest text-on-surface-variant mb-2" data-key="form_details">Project Details *</label>
              <textarea id="c-details" rows="5" required placeholder="Describe your project, goals, and any references you love..." class="w-full bg-surface-container-low px-4 py-3 text-on-surface text-sm border border-outline-variant focus:border-primary focus:outline-none transition-colors resize-none"></textarea>
            </div>
            <div class="flex items-start gap-3">
              <input type="checkbox" id="c-gdpr" required class="mt-1 accent-primary w-4 h-4 flex-shrink-0"/>
