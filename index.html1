// ── PROJECT MODALS (Portfolio) ────────────────────
const projects = {
  titan: { title:"01 — Titan Protocol", tag:"Fintech / Backend Scalability", year:"2024", stack:"Next.js · PostgreSQL · Redis · Stripe", desc:"Enterprise financial dashboard processing 8,000+ daily transactions with real-time risk scoring, portfolio analytics, and compliance reporting. Built for a Swiss fintech startup.", metrics:[{l:"Transactions/day",v:"8,291"},{l:"Load time",v:"0.6s"},{l:"Uptime",v:"99.9%"},{l:"Data points",v:"10M+"}] },
  ether: { title:"02 — Ether Engine", tag:"E-Commerce / Real-time Inventory", year:"2024", stack:"React · Node.js · MongoDB · Stripe", desc:"Custom fashion storefront with real-time inventory sync, advanced filtering, wishlist, multi-currency checkout, and vendor analytics dashboard.", metrics:[{l:"Products",v:"4,200+"},{l:"Conversion",v:"+34%"},{l:"Load time",v:"0.8s"},{l:"Uptime",v:"99.8%"}] },
  monolith: { title:"03 — Monolith OS", tag:"Design System / Component Library", year:"2024", stack:"React · Storybook · Figma · TypeScript", desc:"Complete design system with 120+ components, design tokens, motion guidelines, and accessibility standards. Used by 3 enterprise clients.", metrics:[{l:"Components",v:"120+"},{l:"Tokens",v:"340+"},{l:"Accessibility",v:"WCAG AA"},{l:"Bundle",v:"12kb"}] },
  hyperion: { title:"04 — Hyperion Core", tag:"Aerospace Logistics Dashboard", year:"2025", stack:"React · WebSockets · D3.js · AWS", desc:"Mission-critical aerospace logistics platform tracking 247 active flights in real-time. 60fps data visualization, zero-latency alerts, and geo-fencing capabilities.", metrics:[{l:"Active flights",v:"247"},{l:"Latency",v:"<1ms"},{l:"Refresh",v:"60fps"},{l:"Data points",v:"10M+"}] },
  atlas: { title:"05 — Atlas Global", tag:"Logistics / Geo-Fencing", year:"2025", stack:"Vue.js · Mapbox · Node.js · PostgreSQL", desc:"Global shipment tracking platform with live geo-fencing, customs alerts, delivery ETAs, and carrier API integrations across 40+ countries.", metrics:[{l:"Active routes",v:"124"},{l:"On-time rate",v:"97.2%"},{l:"Countries",v:"40+"},{l:"API calls/day",v:"500k"}] },
  nexus: { title:"06 — Nexus Learn", tag:"EdTech / LMS Platform", year:"2024", stack:"Next.js · PostgreSQL · WebRTC · Stripe", desc:"Full LMS platform with live streaming, course progress tracking, certificate generation, and integrated payment system. Hosts 200+ courses.", metrics:[{l:"Students",v:"12,400"},{l:"Courses",v:"200+"},{l:"Live viewers",v:"2,847"},{l:"Completion",v:"78%"}] },
  medicore: { title:"07 — MediCore", tag:"HealthTech / Patient Portal", year:"2025", stack:"React · Node.js · PostgreSQL · HL7", desc:"HIPAA-compliant patient portal with appointment scheduling, prescription management, real-time vitals tracking, and secure doctor-patient messaging.", metrics:[{l:"Patients",v:"5,200+"},{l:"HIPAA",v:"Compliant"},{l:"Uptime",v:"99.99%"},{l:"Response",v:"<200ms"}] },
  vendo: { title:"08 — Vendo Prime", tag:"E-Commerce / Multi-vendor", year:"2024", stack:"Next.js · PostgreSQL · Stripe Connect · Redis", desc:"Multi-vendor marketplace with independent vendor dashboards, split payments via Stripe Connect, automated shipping integrations, and admin moderation tools.", metrics:[{l:"Vendors",v:"340+"},{l:"Products",v:"18,000+"},{l:"Revenue/mo",v:"$420k"},{l:"Orders/day",v:"890"}] }
};

function openProject(id) {
  const p = projects[id];
  if (!p) return;
  document.getElementById('templateTitle').textContent = p.title;
  document.getElementById('templateContent').innerHTML = `
    <div class="space-y-6">
      <div class="flex flex-wrap gap-4 items-start">
        <div class="flex-1">
          <span class="sec-label block mb-2">${p.tag}</span>
          <p class="text-on-surface-variant text-sm leading-relaxed">${p.desc}</p>
        </div>
        <div class="text-right">
          <div class="font-mono text-xs text-on-surface-variant uppercase tracking-widest mb-1">Year</div>
          <div class="font-black text-2xl">${p.year}</div>
        </div>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        ${p.metrics.map(m=>`<div class="p-4 border border-outline-variant bg-surface-container-low text-center"><div class="font-black text-xl text-primary">${m.v}</div><div class="font-mono text-xs text-on-surface-variant uppercase mt-1">${m.l}</div></div>`).join('')}
      </div>
      <div class="p-4 border border-outline-variant bg-surface-container-low">
        <div class="font-mono text-xs text-on-surface-variant uppercase tracking-widest mb-2">Tech Stack</div>
        <div class="flex flex-wrap gap-2">
          ${p.stack.split(' · ').map(s=>`<span class="px-3 py-1 bg-primary text-white font-mono text-xs">${s}</span>`).join('')}
        </div>
      </div>
      <div class="p-6 bg-primary/5 border border-primary/20">
        <p class="font-mono text-xs text-on-surface-variant uppercase tracking-widest mb-2">Want something similar?</p>
        <p class="text-sm text-on-surface-variant mb-4">We can build a custom solution tailored to your exact requirements. Let's discuss your project.</p>
        <a href="#contact" onclick="closeTemplate()" class="inline-flex items-center gap-2 bg-primary text-white px-6 py-3 font-label text-xs uppercase tracking-widest hover:bg-primary-container transition-colors">
          Start Your Project <span class="material-symbols-outlined text-sm">arrow_forward</span>
        </a>
      </div>
    </div>`;
  document.getElementById('templateModal').classList.add('show');
  document.body.style.overflow = 'hidden';
}

// ── CURRENT STATE ────────────────────────────────
let currentLang = 'en';
let testimonialIndex = 0;
let testimonialCount = 4;

// ── LANG SWITCHER ────────────────────────────────
function setLang(lang) {
  currentLang = lang;
  document.querySelectorAll('[data-key]').forEach(el => {
    const key = el.dataset.key;
    if (i18n[lang] && i18n[lang][key]) {
      el.textContent = i18n[lang][key];
    }
  });
  document.querySelectorAll('.lang-btn').forEach(btn => {
    btn.classList.remove('active');
    if (btn.textContent.trim().toLowerCase() === lang) btn.classList.add('active');
  });
  document.documentElement.lang = lang;
}

// ── DARK MODE ────────────────────────────────────
function toggleDark() {
  document.documentElement.classList.toggle('dark');
  const icon = document.getElementById('darkIcon');
  icon.textContent = document.documentElement.classList.contains('dark') ? 'light_mode' : 'dark_mode';
}

// ── MOBILE MENU ──────────────────────────────────
function toggleMobileMenu() {
  document.getElementById('mobileMenu').classList.toggle('open');
}

// ── SCROLL PROGRESS ──────────────────────────────
window.addEventListener('scroll', () => {
  const scrolled = (window.scrollY / (document.body.scrollHeight - window.innerHeight)) * 100;
  document.getElementById('scrollProgress').style.width = scrolled + '%';
});

// ── FAQ ──────────────────────────────────────────
function toggleFaq(btn) {
  const item = btn.closest('.faq-item');
  const content = item.querySelector('.faq-content');
  const isOpen = item.classList.contains('open');
  document.querySelectorAll('.faq-item.open').forEach(i => {
    i.classList.remove('open');
    i.querySelector('.faq-content').classList.remove('open');
  });
  if (!isOpen) {
    item.classList.add('open');
    content.classList.add('open');
  }
}

// ── TESTIMONIALS ─────────────────────────────────
function updateTestimonial() {
  const track = document.getElementById('testimonialTrack');
  const itemsPerView = window.innerWidth >= 1024 ? 3 : window.innerWidth >= 768 ? 2 : 1;
  const maxIndex = testimonialCount - itemsPerView;
  if (testimonialIndex > maxIndex) testimonialIndex = 0;
  if (testimonialIndex < 0) testimonialIndex = maxIndex;
  const pct = (100 / itemsPerView) * testimonialIndex;
  track.style.transform = `translateX(-${pct}%)`;
  const dots = document.getElementById('testimonialDots');
  dots.innerHTML = '';
  for (let i = 0; i <= maxIndex; i++) {
    const d = document.createElement('button');
    d.className = `w-2 h-2 transition-all ${i === testimonialIndex ? 'bg-primary w-6' : 'bg-outline-variant'}`;
    d.onclick = () => { testimonialIndex = i; updateTestimonial(); };
    dots.appendChild(d);
  }
}
function nextTestimonial() { testimonialIndex++; updateTestimonial(); }
function prevTestimonial() { testimonialIndex--; updateTestimonial(); }
window.addEventListener('resize', updateTestimonial);
updateTestimonial();

// ── SERVICE PILLS ────────────────────────────────
document.querySelectorAll('.srv-pill').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.srv-pill').forEach(b => {
      b.classList.remove('bg-primary','text-white','border-primary');
    });
    btn.classList.add('bg-primary','text-white','border-primary');
    document.getElementById('c-service').value = btn.dataset.value;
  });
});
document.querySelectorAll('.bgt-pill').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.bgt-pill').forEach(b => {
      b.classList.remove('bg-secondary','text-white','border-secondary');
    });
    btn.classList.add('bg-secondary','text-white','border-secondary');
    document.getElementById('c-budget').value = btn.dataset.value;
  });
});

// ── TEMPLATE MODAL ───────────────────────────────
function openTemplate(type) {
  const tmpl = templates[type];
  if (!tmpl) return;
  document.getElementById('templateTitle').textContent = tmpl.title;
  document.getElementById('templateContent').innerHTML = tmpl.html;
  document.getElementById('templateModal').classList.add('show');
  document.body.style.overflow = 'hidden';
}
function closeTemplate() {
  document.getElementById('templateModal').classList.remove('show');
  document.body.style.overflow = '';
}
document.getElementById('templateModal').addEventListener('click', e => {
  if (e.target === document.getElementById('templateModal')) closeTemplate();
});

// ── CONTACT FORM ─────────────────────────────────
document.getElementById('mainContactForm').addEventListener('submit', async e => {
  e.preventDefault();
  const name    = document.getElementById('c-name').value.trim();
  const email   = document.getElementById('c-email').value.trim();
  const details = document.getElementById('c-details').value.trim();
  const gdpr    = document.getElementById('c-gdpr').checked;
  const errorDiv = document.getElementById('contactError');

  if (!name || !email || !details || !gdpr) {
    errorDiv.textContent = !gdpr ? (currentLang==='ro' ? 'Acceptă politica de confidențialitate.' : 'Please accept the privacy policy.') : (currentLang==='ro' ? 'Completează câmpurile obligatorii.' : 'Please fill in all required fields.');
    errorDiv.classList.remove('hidden');
    return;
  }
  if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
    errorDiv.textContent = currentLang==='ro' ? 'Email invalid.' : 'Invalid email address.';
    errorDiv.classList.remove('hidden');
    return;
  }
  errorDiv.classList.add('hidden');

  const btn = document.getElementById('contactSubmitBtn');
  const btnText = document.getElementById('contactBtnText');
  const spinner = document.getElementById('contactSpinner');
  btn.disabled = true;
  btnText.textContent = '...';
  spinner.classList.remove('hidden');

  try {
    const res = await fetch('/submit', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({
        name, email,
        phone:    document.getElementById('c-phone').value.trim(),
        business: document.getElementById('c-business').value.trim(),
        service:  document.getElementById('c-service').value,
        budget:   document.getElementById('c-budget').value,
        details,
        source:   'Main Website',
      })
    });
    if (!res.ok) throw new Error();
    document.getElementById('mainContactForm').reset();
    document.querySelectorAll('.srv-pill,.bgt-pill').forEach(p => p.classList.remove('bg-primary','text-white','border-primary','bg-secondary','border-secondary'));
    document.getElementById('c-service').value = '';
    document.getElementById('c-budget').value = '';
    const modal = document.getElementById('successModal');
    modal.style.display = 'flex';
  } catch {
    errorDiv.textContent = currentLang==='ro' ? 'Eroare la trimitere. Încearcă din nou.' : 'Submission error. Please try again.';
    errorDiv.classList.remove('hidden');
  } finally {
    btn.disabled = false;
    btnText.dataset.key = 'form_submit';
    btnText.textContent = i18n[currentLang]['form_submit'];
    spinner.classList.add('hidden');
  }
});

// ── SMOOTH NAV ACTIVE STATE ───────────────────────
const sections = document.querySelectorAll('section[id]');
const navLinks = document.querySelectorAll('a.nav-link');
const observer = new IntersectionObserver(entries => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      navLinks.forEach(link => {
        link.classList.remove('text-primary','border-b-2','border-primary');
        if (link.getAttribute('href') === '#'+entry.target.id) {
          link.classList.add('text-primary');
        }
      });
    }
  });
}, { threshold: 0.3 });
sections.forEach(s => observer.observe(s));

// Init
setLang('en');
</script>

</body>
</html>

```
