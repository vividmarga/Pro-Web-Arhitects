<section id="contact" class="py-32 px-6 lg:px-24 bg-surface">
  <div class="max-w-[1440px] mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-20">
      <div class="lg:col-span-2">
        <span class="sec-label block mb-6" data-key="contact_label">Get In Touch</span>
