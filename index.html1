            <div id="contactError" class="hidden p-4 bg-red-50 border border-red-200 text-red-700 text-sm"></div>
            <button type="submit" id="contactSubmitBtn" class="shimmer w-full py-5 bg-primary text-white font-label uppercase tracking-widest text-sm flex items-center justify-center gap-3 hover:bg-primary-container transition-colors">
              <span id="contactBtnText" data-key="form_submit">Send & Receive Free Estimate</span>
              <span id="contactSpinner" class="hidden"><svg class="animate-spin w-5 h-5" viewBox="0 0 24 24" fill="none"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/></svg></span>
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

