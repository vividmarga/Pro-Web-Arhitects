<!-- ═══════════════════════════════════════════════════
     METHODOLOGY
════════════════════════════════════════════════════ -->
<section id="methodology" class="py-32 px-6 lg:px-24 bg-surface-container-low">
  <div class="max-w-[1440px] mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-24 items-start">
      <div class="lg:sticky lg:top-32">
        <span class="sec-label block mb-6" data-key="meth_label">How We Work</span>
        <h2 class="font-black text-5xl md:text-7xl uppercase leading-[.9] mb-12" data-key="meth_title">The<br/><span class="text-primary">Engineering</span><br/>Standard</h2>

        <div class="space-y-8">
          <div class="flex gap-6 items-start">
            <div class="w-12 h-12 bg-primary/10 flex items-center justify-center text-primary font-black shrink-0">01</div>
            <div>
              <h4 class="font-bold uppercase mb-2" data-key="meth_1_title">Atomic Precision</h4>
